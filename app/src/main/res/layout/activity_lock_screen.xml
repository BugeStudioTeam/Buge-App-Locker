<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lock_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="64dp"
        android:paddingBottom="32dp">

        <!-- App icon -->
        <ImageView
            android:id="@+id/img_app_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_lock_lock" />

        <!-- App name -->
        <TextView
            android:id="@+id/txt_app_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="14dp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/lock_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/lock_subtitle"
            android:textSize="14sp"
            android:textColor="@color/lock_text_secondary"
            android:paddingTop="6dp"
            android:paddingBottom="32dp" />

        <!-- PIN input card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/lock_surface"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_pin"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/lock_hint"
                    app:endIconMode="password_toggle"
                    app:boxStrokeColor="@color/lock_primary"
                    app:hintTextColor="@color/lock_text_secondary"
                    app:endIconTint="@color/lock_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_pin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberPassword"
                        android:maxLength="8"
                        android:imeOptions="actionDone"
                        android:textColor="@color/lock_text_primary" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/txt_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lock_wrong_pin"
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_unlock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/lock_unlock"
                    android:textSize="16sp"
                    android:paddingVertical="14dp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_go_home"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/lock_go_home"
                    android:textColor="@color/lock_text_secondary"
                    app:strokeColor="@color/lock_text_secondary"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
